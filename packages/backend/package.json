{
  "name": "@hat/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 3001",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 execute hat-db --local --file=migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute hat-db --remote --file=migrations/0001_init.sql",
    "clean": "rm -rf dist .wrangler"
  },
  "dependencies": {
    "@hat/common": "workspace:*",
    "@worldcoin/idkit-server": "^1.1.0",
    "ethers": "^6.14.0",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.22.0"
  }
}
